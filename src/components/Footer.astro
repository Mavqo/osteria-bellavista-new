---
import { useTranslations } from '../lib/i18n';
import restaurant from '../data/restaurant.json';

const t = useTranslations(Astro.currentLocale || 'it');
const currentYear = new Date().getFullYear();
---

<footer id="contact" class="bg-primary dark:bg-charcoal-dark text-alabaster dark:text-alabaster py-16">
  <div class="container mx-auto px-4">
    <!-- Newsletter Section -->
    <div class="flex flex-col md:flex-row items-center justify-between border-b border-alabaster/10 dark:border-alabaster/10 pb-12 mb-12 gap-8">
      <div class="text-center md:text-left">
        <h3 class="font-serif text-2xl md:text-3xl mb-2">{t('footer.newsletter.heading')}</h3>
        <p class="text-alabaster/60 dark:text-alabaster/60 text-sm">{t('footer.newsletter.description')}</p>
      </div>
      <form id="footer-newsletter-form" class="flex w-full md:w-auto max-w-md gap-2" novalidate>
        <input
          id="footer-newsletter-email"
          type="email"
          placeholder={t('footer.newsletter.placeholder')}
          class="flex-1 px-4 py-3 bg-alabaster/5 dark:bg-alabaster/5 border border-alabaster/10 dark:border-alabaster/10 rounded-sm text-alabaster dark:text-alabaster placeholder:text-alabaster/40 dark:placeholder:text-alabaster/40 focus:outline-none focus:border-secondary transition-colors"
          required
          aria-label={t('footer.newsletter.placeholder')}
        />
        <button
          type="submit"
          id="footer-newsletter-btn"
          class="px-6 py-3 bg-secondary dark:bg-secondary text-alabaster dark:text-alabaster font-medium rounded-sm hover:bg-secondary/90 hover:text-alabaster dark:hover:bg-secondary/90 dark:hover:text-alabaster transition-colors duration-300"
        >
          {t('footer.newsletter.button')}
        </button>
      </form>
      <p id="footer-newsletter-success" class="hidden text-secondary text-sm font-medium">{t('newsletterModal.success')}</p>
    </div>

    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- Brand Column -->
      <div class="space-y-4">
        <a href="/" class="text-2xl font-serif font-bold tracking-tight inline-block">
          {t('site.title')}
        </a>
        <p class="text-alabaster/60 dark:text-alabaster/60 text-sm leading-relaxed max-w-xs">
          {t('site.description')}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-serif text-lg mb-6">{t('nav.home')}</h4>
        <nav class="flex flex-col space-y-3">
          <a href="#story" class="text-alabaster/70 dark:text-alabaster/70 hover:text-secondary transition-colors">{t('nav.story')}</a>
          <a href="#menu" class="text-alabaster/70 dark:text-alabaster/70 hover:text-secondary transition-colors">{t('nav.menu')}</a>
          <a href="#events" class="text-alabaster/70 dark:text-alabaster/70 hover:text-secondary transition-colors">{t('nav.privateDining')}</a>
          <a href="#location" class="text-alabaster/70 dark:text-alabaster/70 hover:text-secondary transition-colors">{t('nav.location')}</a>
          <a href="#reservations" class="text-alabaster/70 dark:text-alabaster/70 hover:text-secondary transition-colors">{t('nav.reservations')}</a>
        </nav>
      </div>

      <!-- Contact & Hours -->
      <div>
        <h4 class="font-serif text-lg mb-6">{t('footer.contact.heading')}</h4>
        <div class="space-y-4 text-alabaster/70 dark:text-alabaster/70 text-sm">
          <p>{restaurant.address.display}</p>
          <p><a href="tel:+41919213560" class="hover:text-secondary transition-colors">{t('footer.contact.phone')}</a></p>
          <p><a href="mailto:info@osteriabellavista.ch" class="hover:text-secondary transition-colors">{t('footer.contact.email')}</a></p>
          <div class="pt-2 border-t border-alabaster/10 dark:border-alabaster/10 mt-4">
            <p class="mt-4">{t('footer.hours.weekdays')}</p>
            <p>{t('footer.hours.dinner')}</p>
            <p class="text-alabaster/50 mt-1">{t('footer.hours.closed')}</p>
          </div>
        </div>
      </div>

      <!-- Social -->
      <div>
        <h4 class="font-serif text-lg mb-6">{t('footer.social.heading')}</h4>
        <div class="flex gap-4">
          <a href="https://instagram.com/osteriabellavista" target="_blank" rel="noopener noreferrer" aria-label={t('footer.social.instagram')} class="w-10 h-10 flex items-center justify-center rounded-full bg-alabaster/5 dark:bg-alabaster/5 hover:bg-secondary hover:text-alabaster transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <a href="https://facebook.com/OsteriaBellavistaLugano" target="_blank" rel="noopener noreferrer" aria-label={t('footer.social.facebook')} class="w-10 h-10 flex items-center justify-center rounded-full bg-alabaster/5 dark:bg-alabaster/5 hover:bg-secondary hover:text-alabaster transition-colors duration-300">
             <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="pt-8 border-t border-alabaster/10 dark:border-alabaster/10 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-alabaster/40 dark:text-alabaster/40">
      <p>{t('footer.legal.copyright').replace('{{year}}', currentYear.toString())}</p>
      <div class="flex gap-6">
        <a href="#contact" class="hover:text-alabaster dark:hover:text-alabaster transition-colors">{t('footer.legal.privacy')}</a>
        <a href="#contact" class="hover:text-alabaster dark:hover:text-alabaster transition-colors">{t('footer.legal.terms')}</a>
      </div>
    </div>
    <!-- Demo indicator -->
    <div class="mt-4 pt-4 border-t border-alabaster/5 dark:border-alabaster/5 text-center">
      <p class="text-xs text-alabaster/30 dark:text-alabaster/30 tracking-wide">
        {t('footer.legal.demoNotice')}
      </p>
    </div>
  </div>
</footer>

<script>
  const form = document.getElementById('footer-newsletter-form') as HTMLFormElement | null;
  const emailInput = document.getElementById('footer-newsletter-email') as HTMLInputElement | null;
  const btn = document.getElementById('footer-newsletter-btn') as HTMLButtonElement | null;
  const successMsg = document.getElementById('footer-newsletter-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = emailInput?.value.trim();
    if (!email || !emailInput?.checkValidity()) return;

    if (btn) {
      btn.disabled = true;
      btn.textContent = '...';
    }

    // Simulate async submission
    setTimeout(() => {
      form.classList.add('hidden');
      successMsg?.classList.remove('hidden');
    }, 800);
  });
</script>
